# .gitignore file edit karo
@"
# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files (IMPORTANT!)
.env
frontend/.env
backend/.env
.env.local
.env.*
*.env

# Uploads
backend/uploads/
uploads/

# Build files
build/
dist/
frontend/build/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
"@ | Out-File -FilePath .gitignore -Encoding UTF8